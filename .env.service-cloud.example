# Online Service Cloud Capacitor — copy to .env.service-cloud for local Cap builds.
# Do NOT set VITE_DEPLOYMENT_MODE=service-mobile (that is Offline only).

# Cloud API origin (required for Cap APK — relative /api won't hit the server)
VITE_API_ORIGIN=https://dhandho.onrender.com

# Optional build stamp
# VITE_APP_VERSION=0.1.0
