# Copy to .env and fill in real values. Never commit .env.

# ── Required (server) ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DATABASE_NAME
JWT_SECRET=replace-with-a-random-string-at-least-32-chars
# Optional but recommended in production: dedicated key for GST NIC secret encryption
# (falls back to JWT_SECRET if unset; set a different 32+ char value to separate concerns)
# SECRETS_ENCRYPTION_KEY=replace-with-a-different-random-string-at-least-32-chars
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_PASSWORD=replace-with-a-strong-password-min-12-chars

# ── Required in production ─────────────────────────────────────────────────────
# NODE_ENV=production
# ALLOWED_ORIGINS=https://dhandho.app,https://www.dhandho.app
# DATABASE_SSL=true
# (TLS is always enabled when NODE_ENV=production)

# ── Server (optional) ──────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# JWT_EXPIRES_IN=7d
# DATABASE_POOL_SIZE=10
# DATABASE_SSL=true
# DATABASE_SSL_REJECT_UNAUTHORIZED=true
# TRUST_PROXY=1
# PUBLIC_APP_URL=https://your.app
# REQUIRE_ELECTRON=false
# DEPLOYMENT_MODE=cloud
# LOGTAIL_TOKEN=
# LOGTAIL_ENDPOINT=https://sXXXX.REGION.betterstackdata.com

# CLOUD_VERSION=

# GST NIC API public keys (PEM). Server-side only — never VITE_ / client.
# GSTN_SANDBOX_PUBLIC_KEY=
# GSTN_PRODUCTION_PUBLIC_KEY=
# GSTN_PUBLIC_KEY=

# ── Electron cloud wrapper (build-time) ────────────────────────────────────────
# DG_CLOUD_URL=https://your-cloud-host

