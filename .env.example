# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/splendor_erp

# Auth
JWT_SECRET=generate-a-random-64-char-string-here

# Super Admin (first-time setup only)
SUPER_ADMIN_EMAIL=admin@yourdomain.com
SUPER_ADMIN_PASSWORD=change-this-to-a-strong-password

# App public URL (used by Electron apps)
# DG_CLOUD_URL=https://dg-erp.onrender.com   # set in Electron build env

# Optional
# LOGTAIL_TOKEN=your-betterstack-token
# DATABASE_POOL_SIZE=10
# NODE_ENV=production
