# Public-safe only — embedded in the Service Mobile Capacitor build.
VITE_DEPLOYMENT_MODE=service-mobile
# Cloud host for license activate / heartbeat / backup (not ERP data).
# Local `vite --mode service-mobile` ignores this and proxies /api → Render (see vite.config + cloud.ts).
# Live Render host today. After service `dhandho` is up, switch to https://dhandho.onrender.com
VITE_API_ORIGIN=https://dg-erp.onrender.com
VITE_APP_VERSION=0.1.0
