{
  "name": "splendor-erp",
  "private": true,
  "version": "2.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "server": "tsx server/index.ts",
    "start": "tsx server/index.ts",
    "build": "vite build",
    "build:prod": "vite build",
    "dev:all": "npm run server & npm run dev",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "electron:cloud:dev": "electron electron/cloud/main.ts",
    "electron:onprem:dev": "npm run tsc:electron && electron electron/onprem/main.js",
    "tsc:electron": "node_modules/.bin/tsc -p tsconfig.electron.json",
    "build:electron:cloud": "npm run tsc:electron && electron-builder --config electron-cloud.config.cjs",
    "build:electron:cloud:win": "npm run tsc:electron && electron-builder --config electron-cloud.config.cjs --win",
    "build:electron:cloud:mac": "npm run tsc:electron && electron-builder --config electron-cloud.config.cjs --mac",
    "build:electron:onprem": "npm run build && npm run tsc:electron && electron-builder --config electron-onprem.config.cjs",
    "build:electron:onprem:win": "npm run build && npm run tsc:electron && electron-builder --config electron-onprem.config.cjs --win",
    "build:electron:onprem:mac": "npm run build && npm run tsc:electron && electron-builder --config electron-onprem.config.cjs --mac"
  },
  "main": "electron/cloud/main.js",
  "dependencies": {
    "@logtail/node": "^0.5.8",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "bcrypt": "^6.0.0",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.9",
    "embedded-postgres": "^18.4.0-beta.17",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "html5-qrcode": "^2.3.8",
    "jsbarcode": "^3.12.3",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "vite": "^6.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.20.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.1",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^10.0.3",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vitest": "^4.1.9"
  },
  "description": "Dhandho — Business Management Software for Indian SMEs",
  "author": {
    "name": "Dhandho",
    "email": "patelprathamesh007@gmail.com"
  }
}
