{
  "name": "splendor-erp",
  "private": true,
  "version": "2.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "server": "tsx server/index.ts",
    "start": "tsx server/index.ts",
    "build": "vite build",
    "build:prod": "vite build",
    "dev:all": "npm run server & npm run dev",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"server/**/*.ts\" \"tests/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" \"server/**/*.ts\" \"tests/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"server/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"server/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "analyze": "vite build --mode analyze",
    "prepare": "node -e \"try{require('child_process').execSync('husky',{stdio:'inherit'})}catch(e){process.exit(0)}\"",
    "electron:cloud:dev": "electron electron/cloud/main.ts",
    "electron:onprem:dev": "npm run tsc:electron && electron electron/onprem/main.js",
    "electron:onprem:dev:local": "npm run tsc:electron && DG_CLOUD_URL=http://localhost:3001 electron electron/onprem/main.js",
    "tsc:electron": "node_modules/.bin/tsc -p tsconfig.electron.json",
    "build:electron:cloud": "npm run tsc:electron && electron-builder --config electron-cloud.config.cjs",
    "build:electron:cloud:win": "npm run tsc:electron && electron-builder --config electron-cloud.config.cjs --win",
    "build:electron:cloud:mac": "npm run tsc:electron && electron-builder --config electron-cloud.config.cjs --mac",
    "build:electron:onprem": "npm run build && npm run tsc:electron && electron-builder --config electron-onprem.config.cjs",
    "build:electron:onprem:win": "npm run build && npm run tsc:electron && electron-builder --config electron-onprem.config.cjs --win",
    "build:electron:onprem:mac": "npm run build && npm run tsc:electron && electron-builder --config electron-onprem.config.cjs --mac",
    "build:service-mobile": "vite build --mode service-mobile --outDir dist-service-mobile",
    "build:service-cloud": "vite build --mode service-cloud --outDir dist-service-cloud",
    "build:service-phone": "vite build --mode service-phone --outDir dist-service-phone",
    "cap:sync": "npm run build:service-phone && npx cap sync && bash scripts/android-set-product.sh offline",
    "cap:sync:cloud": "bash scripts/cap-sync-cloud.sh",
    "cap:android": "npm run cap:sync && npx cap open android",
    "cap:android:cloud": "npm run cap:sync && npx cap open android",
    "cap:ios": "npm run cap:sync && npx cap open ios",
    "cap:run:android": "npm run cap:sync && npx cap run android",
    "cap:run:ios": "npm run cap:sync && npx cap run ios",
    "ci:android": "bash scripts/ci-build-android.sh",
    "ci:ios": "MOBILE_PRODUCT=offline bash scripts/ci-build-ios.sh",
    "ci:ios:online": "MOBILE_PRODUCT=online bash scripts/ci-build-ios.sh"
  },
  "main": "electron/cloud/main.js",
  "dependencies": {
    "@capacitor/app": "^8.1.1",
    "@capacitor/core": "^8.4.2",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capgo/capacitor-printer": "^8.1.1",
    "@electric-sql/pglite": "^0.5.4",
    "@logtail/node": "^0.5.8",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "dotenv": "^17.4.2",
    "embedded-postgres": "^18.4.0-beta.17",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "html2pdf.js": "^0.14.0",
    "html5-qrcode": "^2.3.8",
    "jose": "^6.2.3",
    "jsbarcode": "^3.12.3",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.24.0",
    "motion": "^12.23.24",
    "pg": "^8.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "vite": "^6.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/ios": "^8.4.2",
    "@eslint/js": "^9.39.2",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.20.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.1",
    "@vitest/coverage-v8": "^4.1.10",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "rollup-plugin-visualizer": "^6.0.5",
    "supertest": "^7.2.2",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 200",
      "prettier --write"
    ]
  },
  "description": "Dhandho — Business Management Software for Indian SMEs",
  "author": {
    "name": "Dhandho",
    "email": "patelprathamesh007@gmail.com"
  }
}
