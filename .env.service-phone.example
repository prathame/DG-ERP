# Unified Capacitor phone shell — copy to .env.service-phone for Cap builds.
# First launch: user picks Online (cloud seats) or Offline (DG-SM- / PGlite) once.
# Do NOT set VITE_DEPLOYMENT_MODE=service-mobile (that forces Offline-only, no picker).

VITE_DEPLOYMENT_MODE=service-phone

# Cloud API origin (Online ERP + Offline license activate/heartbeat).
# Use Render until dhandho.app has public DNS (currently NXDOMAIN).
VITE_API_ORIGIN=https://dhandho-2kdx.onrender.com

# Optional build stamp
# VITE_APP_VERSION=0.1.0
